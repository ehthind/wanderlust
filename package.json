{
  "name": "wanderlust",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm -r --parallel --stream --filter @wanderlust/web --filter @wanderlust/temporal-worker dev",
    "dev:web": "corepack pnpm --filter @wanderlust/web dev",
    "dev:worker": "corepack pnpm --filter @wanderlust/temporal-worker dev",
    "build": "corepack pnpm -r --filter @wanderlust/web --filter @wanderlust/temporal-worker build",
    "test": "corepack pnpm -r --filter @wanderlust/web --filter @wanderlust/temporal-worker test",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "corepack pnpm -r --filter @wanderlust/web --filter @wanderlust/temporal-worker typecheck",
    "check": "node tools/checks/architecture.mjs && node tools/checks/docs.mjs && node tools/checks/plans.mjs && node tools/checks/files.mjs",
    "check:delivery": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm check && corepack pnpm test && corepack pnpm playwright:smoke",
    "check:architecture": "node tools/checks/architecture.mjs",
    "check:docs": "node tools/checks/docs.mjs",
    "check:plans": "node tools/checks/plans.mjs",
    "check:files": "node tools/checks/files.mjs",
    "check:observability": "node tools/checks/observability.mjs",
    "symphony:setup": "bash tools/symphony/setup-upstream.sh",
    "symphony:run": "bash tools/symphony/run-upstream.sh",
    "turbo:dev": "corepack pnpm exec turbo run dev --parallel",
    "turbo:typecheck": "corepack pnpm exec turbo run typecheck",
    "playwright:smoke": "playwright test --grep @smoke"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.54.1",
    "@types/node": "^24.3.0",
    "glob": "^11.0.3",
    "tsx": "^4.20.3",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "zod": "^4.1.12"
  }
}
